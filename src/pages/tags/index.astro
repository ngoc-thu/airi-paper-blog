---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { useTranslations } from "@/i18n";
import config from "@/config";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const tags = getUniqueTags(posts);

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.pages.tagsTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.tagsTitle} pageDesc={t.pages.tagsDesc}>
    {
      tags.length > 0 ? (
        <ul class="flex flex-wrap gap-6">
          {tags.map(({ tag, tagName }) => (
            <Tag {tag} {tagName} />
          ))}
        </ul>
      ) : (
        <section class="glass-panel rounded-2xl p-6">
          <p class="text-muted-foreground text-sm tracking-[0.18em] uppercase">
            {t.empty.noTagsLabel}
          </p>
          <h2 class="mt-3 text-3xl font-semibold">{t.empty.noTagsTitle}</h2>
          <p class="text-muted-foreground mt-3 max-w-2xl text-lg">
            {t.empty.noTagsDesc}
          </p>
        </section>
      )
    }
  </Main>

  <Footer />
</Layout>
